POSTGRES_DB=agentmesh
POSTGRES_USER=agentmesh
POSTGRES_PASSWORD=agentmesh
DATABASE_URL=postgresql://agentmesh:agentmesh@postgres:5432/agentmesh
CORS_ORIGIN=http://localhost:3002
NEXT_PUBLIC_API_URL=http://localhost:4000
FRONTEND_PORT=3002
PGLITE_DATA_DIR=.agentmesh/pglite
AGENTMESH_WORKER_TOKEN=replace-me-with-a-random-token
VITE_ADMIN_USERNAME=admin@impact-rdc
VITE_ADMIN_PASSWORD=replace-me-with-private-admin-password
VITE_REVIEWER_CODE=replace-me-with-private-reviewer-code
# Prefer DATABASE_URL for real Postgres. If unset, AgentMesh uses durable on-disk PGlite at PGLITE_DATA_DIR.
# Front-end demo gate only. Production verification needs backend auth, roles, and audit logs.
